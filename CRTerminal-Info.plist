<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Custom Info.plist keys merged with the Xcode-generated ones (the standard
     CFBundle* / LSMinimumSystemVersion entries still come from build settings via
     GENERATE_INFOPLIST_FILE=YES). These are the Sparkle auto-update settings. -->
<plist version="1.0">
<dict>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.developer-tools</string>
	<key>SUFeedURL</key>
	<string>https://github.com/mbcltd/CRTerminal/releases/latest/download/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>4+vBKrgfLtlBoDvReotMPcJj5CiUJ+fZVCndEJ5f3N4=</string>
	<!-- Updates are strictly user-initiated: no scheduled background checks
	     (so Sparkle never pops an unsolicited "update available" nag) and no
	     silent downloads. The "Check for Updates…" menu item is the only path
	     to an update. Enforced again at runtime in AppDelegate so it also wins
	     over any value an earlier build persisted to a user's defaults. -->
	<key>SUEnableAutomaticChecks</key>
	<false/>
	<key>SUAutomaticallyUpdate</key>
	<false/>
</dict>
</plist>
